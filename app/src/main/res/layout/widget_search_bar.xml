<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="6dp"
    android:paddingTop="4dp"
    android:paddingRight="6dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/widget_search_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/widget_search_bar_background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Search Icon -->
        <ImageView
            android:id="@+id/widget_search_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_widget_search"
            android:contentDescription="Search Icon"
            android:layout_marginEnd="10dp" />

        <!-- Placeholder Text -->
        <TextView
            android:id="@+id/widget_search_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Search Aura Learning..."
            android:textColor="#94A3B8"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- Voice Search Icon -->
        <ImageView
            android:id="@+id/widget_mic_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_mic"
            android:contentDescription="Voice Search"
            android:layout_marginEnd="10dp" />

        <!-- Aura Brand Logo -->
        <ImageView
            android:id="@+id/widget_brand_logo"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_widget_aura_logo"
            android:contentDescription="Aura Logo" />

    </LinearLayout>

</LinearLayout>
